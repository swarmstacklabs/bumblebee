#!/bin/sh
# Bring up Wi-Fi when a generated wpa_supplicant.conf is present.

WIFI_INTERFACE="wlan0"
WIFI_DEFAULTS="/etc/default/wifi"
WPA_PIDFILE="/var/run/wpa_supplicant-${WIFI_INTERFACE}.pid"
UDHCPC_PIDFILE="/var/run/udhcpc-${WIFI_INTERFACE}.pid"
WIFI_INTERFACE_WAIT_SECONDS="${WIFI_INTERFACE_WAIT_SECONDS:-15}"
WIFI_WAIT_SECONDS="${WIFI_WAIT_SECONDS:-20}"
WIFI_HOSTNAME="${WIFI_HOSTNAME:-}"

[ -r "$WIFI_DEFAULTS" ] && . "$WIFI_DEFAULTS"

detect_wireless_interface() {
  if ip link show "$WIFI_INTERFACE" >/dev/null 2>&1; then
    printf '%s\n' "$WIFI_INTERFACE"
    return 0
  fi

  detected="$(for net_path in /sys/class/net/*; do
    [ -d "$net_path/wireless" ] || continue
    basename "$net_path"
  done)"

  case "$(printf '%s\n' "$detected" | sed '/^$/d' | wc -l)" in
    1)
      printf '%s\n' "$detected" | sed -n '/./p'
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

resolved_iface="$(detect_wireless_interface)" || resolved_iface="$WIFI_INTERFACE"
WIFI_INTERFACE="$resolved_iface"
WPA_PIDFILE="/var/run/wpa_supplicant-${WIFI_INTERFACE}.pid"
UDHCPC_PIDFILE="/var/run/udhcpc-${WIFI_INTERFACE}.pid"

wait_for_wifi_interface() {
  remaining="$WIFI_INTERFACE_WAIT_SECONDS"

  if command -v modprobe >/dev/null 2>&1; then
    modprobe brcmfmac >/dev/null 2>&1 || true
  fi

  while [ "$remaining" -gt 0 ]; do
    resolved_iface="$(detect_wireless_interface)" || resolved_iface=""
    if [ -n "$resolved_iface" ] && ip link show "$resolved_iface" >/dev/null 2>&1; then
      WIFI_INTERFACE="$resolved_iface"
      WPA_PIDFILE="/var/run/wpa_supplicant-${WIFI_INTERFACE}.pid"
      UDHCPC_PIDFILE="/var/run/udhcpc-${WIFI_INTERFACE}.pid"
      return 0
    fi

    sleep 1
    remaining=$((remaining - 1))
  done

  return 1
}

wait_for_wifi_ready() {
  remaining="$WIFI_WAIT_SECONDS"

  while [ "$remaining" -gt 0 ]; do
    if command -v iw >/dev/null 2>&1; then
      if iw dev "$WIFI_INTERFACE" link 2>/dev/null | grep -q '^Connected to '; then
        return 0
      fi
    fi

    if ip -4 -o addr show dev "$WIFI_INTERFACE" 2>/dev/null | grep -q .; then
      return 0
    fi

    sleep 1
    remaining=$((remaining - 1))
  done

  return 1
}

start_dhcp() {
  command -v udhcpc >/dev/null 2>&1 || return 0

  if [ -f "$UDHCPC_PIDFILE" ] && kill -0 "$(cat "$UDHCPC_PIDFILE" 2>/dev/null)" 2>/dev/null; then
    return 0
  fi

  rm -f "$UDHCPC_PIDFILE"

  (
    wait_for_wifi_ready || true
    udhcpc_args="-p $UDHCPC_PIDFILE -i $WIFI_INTERFACE -q -t 10 -T 3"

    if [ -z "$WIFI_HOSTNAME" ] && [ -r /etc/hostname ]; then
      WIFI_HOSTNAME="$(head -n 1 /etc/hostname)"
    fi

    if [ -n "$WIFI_HOSTNAME" ]; then
      udhcpc_args="$udhcpc_args -x hostname:$WIFI_HOSTNAME"
    fi

    # shellcheck disable=SC2086
    udhcpc $udhcpc_args >/dev/null 2>&1 || true
  ) &
}

case "$1" in
  start)
    if wait_for_wifi_interface && [ -f /etc/wpa_supplicant.conf ]; then
      mkdir -p /var/run/wpa_supplicant
      ip link set "$WIFI_INTERFACE" up || true
      if [ ! -f "$WPA_PIDFILE" ] || ! kill -0 "$(cat "$WPA_PIDFILE" 2>/dev/null)" 2>/dev/null; then
        rm -f "$WPA_PIDFILE"
        wpa_supplicant -B -P "$WPA_PIDFILE" -i "$WIFI_INTERFACE" -c /etc/wpa_supplicant.conf
      fi
      start_dhcp
    fi
    ;;
  stop)
    if [ -f "$UDHCPC_PIDFILE" ]; then
      kill "$(cat "$UDHCPC_PIDFILE" 2>/dev/null)" 2>/dev/null || true
      rm -f "$UDHCPC_PIDFILE"
    fi
    if [ -f "$WPA_PIDFILE" ]; then
      kill "$(cat "$WPA_PIDFILE" 2>/dev/null)" 2>/dev/null || true
      rm -f "$WPA_PIDFILE"
    fi
    ;;
  restart)
    "$0" stop
    "$0" start
    ;;
esac
